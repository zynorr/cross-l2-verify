{
  "name": "@cross-l2-verify/integration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx src/create2-demo.ts",
    "demo": "node --import tsx src/create2-demo.ts --keep-alive",
    "demo:plan": "node --import tsx src/create2-demo.ts --dry-run",
    "demo:live-ipfs": "node --import tsx src/create2-demo.ts --keep-alive --require-live-ipfs",
    "demo:testnet": "node --import tsx src/testnet-demo.ts",
    "bulk-import": "node --import tsx src/bulk-import.ts",
    "bulk-import:dry": "DRY_RUN=true node --import tsx src/bulk-import.ts"
  },
  "dependencies": {
    "@cross-l2-verify/sdk": "workspace:*",
    "ethers": "^6.15.0",
    "solc": "^0.8.34"
  }
}
